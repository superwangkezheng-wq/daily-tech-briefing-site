<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.dailytech.qmd.refresh</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/sh</string>
      <string>-lc</string>
      <string>exec "__SUPPORT_DIR__/dailytech_qmd_refresh.sh"</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>WorkingDirectory</key>
    <string>__SUPPORT_DIR__</string>
    <key>StandardOutPath</key>
    <string>__LOG_DIR__/qmd-refresh.out.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/qmd-refresh.err.log</string>
  </dict>
</plist>
